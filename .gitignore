frontend/.env.test.local
frontend/.env.production.local

# Backend (Python) ignore patterns
backend/__pycache__/
**/__pycache__/
*.py[cod]
backend/*.py[cod]
backend/*$py.class
backend/*.so
backend/.Python
backend/build/
backend/develop-eggs/
backend/dist/
backend/downloads/
backend/eggs/
